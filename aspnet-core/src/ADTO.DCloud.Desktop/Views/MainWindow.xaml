<Window x:Class="ADTO.DCloud.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="ADTO DCloud Office Command Center"
        Width="1360"
        Height="820"
        MinWidth="1120"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource DCloudVoidBrush}">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF030613" Offset="0" />
                <GradientStop Color="#FF0B1630" Offset="0.55" />
                <GradientStop Color="#FF14081F" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="26">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border CornerRadius="28" Background="#D90A1022" BorderBrush="#3300E5FF" BorderThickness="1" Padding="24">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="ADTO" Foreground="{StaticResource DCloudCyanBrush}" FontSize="24" FontWeight="Black" />
                        <TextBlock Text="DCloud Office" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,2,0,28" />
                        <Button Content="总览驾驶舱" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" HorizontalContentAlignment="Left" Margin="0,4" />
                        <Button Content="流程审批" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#B8C7E6" HorizontalContentAlignment="Left" Margin="0,4" />
                        <Button Content="组织协同" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#B8C7E6" HorizontalContentAlignment="Left" Margin="0,4" />
                        <Button Content="任务中心" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#B8C7E6" HorizontalContentAlignment="Left" Margin="0,4" />
                        <Button Content="系统配置" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#B8C7E6" HorizontalContentAlignment="Left" Margin="0,4" />
                    </StackPanel>
                    <Button DockPanel.Dock="Bottom" Command="{Binding LogoutCommand}" Content="退出登录" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="{StaticResource DCloudCyanBrush}" BorderBrush="{StaticResource DCloudCyanBrush}" />
                </DockPanel>
            </Border>

            <Grid Grid.Column="1" Margin="24,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border CornerRadius="28" Padding="28" Background="#B30D1830" BorderBrush="#332979FF" BorderThickness="1">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="{Binding Headline}" Foreground="White" FontSize="34" FontWeight="Black" />
                            <TextBlock Text="桌面版办公中枢骨架已启动：登录令牌、配置、日志、后台心跳任务与主界面导航已接入。" Foreground="#93A8D6" FontSize="15" Margin="0,8,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Command="{Binding RefreshCommand}" Content="刷新时钟" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,12,0" />
                            <TextBlock Text="{Binding CurrentTime}" Foreground="{StaticResource DCloudCyanBrush}" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="0,24,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.4*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>

                    <Border Grid.RowSpan="2" CornerRadius="28" Background="#CC0B1224" BorderBrush="#4400E5FF" BorderThickness="1" Padding="28" Margin="0,0,24,0">
                        <StackPanel>
                            <TextBlock Text="办公实时态势" Foreground="White" FontSize="26" FontWeight="Bold" />
                            <TextBlock Text="模块化区域预留：后续可按 Prism Module 加载审批、CRM、HR、消息、报表等功能模块。" Foreground="#8EA0C5" TextWrapping="Wrap" Margin="0,8,0,24" />
                            <UniformGrid Columns="3">
                                <Border CornerRadius="22" Background="#1F00E5FF" Padding="20" Margin="0,0,14,0">
                                    <StackPanel>
                                        <TextBlock Text="128" Foreground="White" FontSize="36" FontWeight="Black" />
                                        <TextBlock Text="待办任务" Foreground="#B8C7E6" />
                                    </StackPanel>
                                </Border>
                                <Border CornerRadius="22" Background="#1F2979FF" Padding="20" Margin="7,0">
                                    <StackPanel>
                                        <TextBlock Text="36" Foreground="White" FontSize="36" FontWeight="Black" />
                                        <TextBlock Text="今日审批" Foreground="#B8C7E6" />
                                    </StackPanel>
                                </Border>
                                <Border CornerRadius="22" Background="#227C4DFF" Padding="20" Margin="14,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="99.9%" Foreground="White" FontSize="36" FontWeight="Black" />
                                        <TextBlock Text="服务在线" Foreground="#B8C7E6" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Border Height="250" CornerRadius="24" Background="#1400E5FF" BorderBrush="#3300E5FF" BorderThickness="1" Margin="0,34,0,0">
                                <Canvas>
                                    <Polyline Points="30,190 120,142 210,164 320,84 430,110 560,54 690,88" Stroke="{StaticResource DCloudCyanBrush}" StrokeThickness="4" />
                                    <Polyline Points="30,210 140,196 250,120 360,148 470,92 590,134 690,70" Stroke="{StaticResource DCloudVioletBrush}" StrokeThickness="3" Opacity="0.74" />
                                </Canvas>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" CornerRadius="28" Background="#CC0B1224" BorderBrush="#337C4DFF" BorderThickness="1" Padding="26" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="登录会话" Foreground="White" FontSize="24" FontWeight="Bold" />
                            <TextBlock Text="用户 ID" Foreground="#8EA0C5" Margin="0,22,0,4" />
                            <TextBlock Text="{Binding UserId}" Foreground="{StaticResource DCloudCyanBrush}" FontSize="28" FontWeight="Bold" />
                            <TextBlock Text="Token Preview" Foreground="#8EA0C5" Margin="0,18,0,4" />
                            <TextBlock Text="{Binding TokenPreview}" Foreground="White" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Grid.Row="1" CornerRadius="28" Background="#CC0B1224" BorderBrush="#332979FF" BorderThickness="1" Padding="26">
                        <StackPanel>
                            <TextBlock Text="下一步模块" Foreground="White" FontSize="24" FontWeight="Bold" />
                            <TextBlock Text="1. 抽象通用 ApiClient 与授权 Header" Foreground="#B8C7E6" Margin="0,20,0,0" />
                            <TextBlock Text="2. 按业务拆分 Prism Modules" Foreground="#B8C7E6" Margin="0,12,0,0" />
                            <TextBlock Text="3. 接入 SignalR 消息、审批提醒与任务中心" Foreground="#B8C7E6" Margin="0,12,0,0" />
                            <TextBlock Text="4. 完成主题切换与本地缓存" Foreground="#B8C7E6" Margin="0,12,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
