<Window x:Class="ADTO.DCloud.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:infra="clr-namespace:ADTO.DCloud.Desktop.Infrastructure"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="ADTO DCloud Login"
        Width="1180"
        Height="720"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource DCloudVoidBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <Grid>
        <Grid.Background>
            <RadialGradientBrush Center="0.72,0.12" GradientOrigin="0.72,0.12" RadiusX="0.9" RadiusY="0.8">
                <GradientStop Color="#FF123B78" Offset="0" />
                <GradientStop Color="#FF070B19" Offset="0.48" />
                <GradientStop Color="#FF02030A" Offset="1" />
            </RadialGradientBrush>
        </Grid.Background>

        <Canvas Opacity="0.48">
            <Ellipse Width="420" Height="420" Canvas.Left="-80" Canvas.Top="-110" Stroke="#6600E5FF" StrokeThickness="2" />
            <Ellipse Width="620" Height="620" Canvas.Right="-210" Canvas.Bottom="-260" Stroke="#557C4DFF" StrokeThickness="2" />
            <Line X1="80" Y1="610" X2="1040" Y2="80" Stroke="#3300E5FF" StrokeThickness="1" />
            <Line X1="0" Y1="240" X2="1180" Y2="240" Stroke="#22337DFF" StrokeThickness="1" />
        </Canvas>

        <Grid Margin="58">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="0.85*" />
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center" Margin="10,0,50,0">
                <Border Width="118" Height="34" CornerRadius="17" Background="#1A00E5FF" BorderBrush="#6600E5FF" BorderThickness="1" HorizontalAlignment="Left">
                    <TextBlock Text="DCloud OS" Foreground="{StaticResource DCloudCyanBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="未来办公 · 数字指挥舱" Foreground="White" FontSize="48" FontWeight="Black" Margin="0,28,0,0" />
                <TextBlock Text="WPF + Prism + MVVM + DI + 配置/日志/任务服务" Foreground="#B8C7E6" FontSize="20" Margin="0,16,0,0" />
                <TextBlock Text="将 .NET 9 WebAPI 办公能力沉淀为桌面端模块化工作台，统一登录、任务、消息、审批与数据驾驶舱。" TextWrapping="Wrap" Foreground="#8EA0C5" FontSize="16" LineHeight="28" Margin="0,24,80,0" />

                <UniformGrid Columns="3" Margin="0,42,80,0">
                    <Border CornerRadius="18" Background="#16172244" BorderBrush="#3300E5FF" BorderThickness="1" Padding="18" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="API" Foreground="{StaticResource DCloudCyanBrush}" FontWeight="Bold" />
                            <TextBlock Text="TokenAuth" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="18" Background="#16172244" BorderBrush="#337C4DFF" BorderThickness="1" Padding="18" Margin="6,0">
                        <StackPanel>
                            <TextBlock Text="UI" Foreground="#FF7C4DFF" FontWeight="Bold" />
                            <TextBlock Text="Material" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="18" Background="#16172244" BorderBrush="#332979FF" BorderThickness="1" Padding="18" Margin="12,0,0,0">
                        <StackPanel>
                            <TextBlock Text="ARCH" Foreground="#FF82B1FF" FontWeight="Bold" />
                            <TextBlock Text="Prism" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>

            <Border Grid.Column="1" MaxWidth="430" Padding="34" CornerRadius="28" Background="#D90B1224" BorderBrush="#6600E5FF" BorderThickness="1" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="42" ShadowDepth="0" Color="#FF00E5FF" Opacity="0.28" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="安全登录" Foreground="White" FontSize="30" FontWeight="Bold" />
                    <TextBlock Text="连接 http://localhost:44380/api/TokenAuth/Authenticate" TextWrapping="Wrap" Foreground="#8EA0C5" Margin="0,8,0,26" />

                    <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:HintAssist.Hint="工号 / 用户名" FontSize="16" Margin="0,0,0,16" />
                    <PasswordBox infra:PasswordBoxAssistant.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedPasswordBox}" materialDesign:HintAssist.Hint="密码" FontSize="16" Margin="0,0,0,24" />

                    <Button Command="{Binding LoginCommand}" Height="52" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource DCloudNeonGradient}" Foreground="White" FontSize="17" FontWeight="Bold">
                        <TextBlock Text="进入办公中枢" />
                    </Button>

                    <ProgressBar IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" Height="4" Margin="0,18,0,0" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#B8C7E6" TextWrapping="Wrap" Margin="0,18,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
